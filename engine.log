SELECT
  lower(c.customer_state) state
, AVG(r.review_score) average_review_score
FROM
  olist_order_reviews_dataset r
INNER JOIN olist_orders_dataset o ON (o.order_id = r.order_id)
INNER JOIN olist_customers_dataset c ON (c.customer_id = o.customer_id)
WHERE ((o.order_delivered_customer_date >= CAST('2023-11-09 00:00:00' AS timestamp with time zone)) AND 
(o.order_delivered_customer_date < CAST('2024-11-09 00:00:00' AS timestamp with time zone)))
GROUP BY lower(c.customer_state)

